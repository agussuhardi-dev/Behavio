# =============================================================================
# Behavio — contoh konfigurasi. Salin lalu isi:
#
#   cp .env.example .env
#
# `.env` di-gitignore dan TIDAK boleh di-commit. Kredensial produksi HANYA di
# `.env` — application.yml hanya berisi default dev lokal (localhost/behavio/behavio)
# yang cocok dengan docker-compose.yml di root.
#
# Dibaca oleh: deploy.sh (via `source`) dan deploy/docker-compose.yml
# (via `env_file:` + substitusi variabel) setelah di-scp ke server.
#
# PENTING — Spring Boot TIDAK membaca .env sendiri. `.env` bekerja karena:
#   • deploy.sh mem-`source`-nya lalu scp ke server,
#   • Docker Compose menyuntikkannya ke container sebagai environment variable.
# Untuk `./gradlew :app:bootRun` di laptop, .env TIDAK terbaca — pakai default
# lokal di application.yml (localhost:5432/behavio/behavio), atau export sendiri:
# `export DB_URL=... && ./gradlew :app:bootRun`.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
# Deploy memakai PostgreSQL DI LUAR compose (tak ada service postgres di
# deploy/docker-compose.yml), jadi host harus dapat dijangkau dari container.
# Untuk dev lokal biarkan kosong — application.yml sudah default ke
# localhost:5432/behavio/behavio, sama dengan docker-compose.yml di root.
DB_URL=jdbc:postgresql://ganti-host-db:5432/behavio
DB_USERNAME=ganti-user
DB_PASSWORD=ganti-password

# Port Admin API + dashboard di dalam container. Diproxy nginx (deploy/nginx.conf),
# jadi tak diekspos ke publik. Ubah di sini berarti ubah juga nginx.conf & healthcheck.
SERVER_PORT=8080

# ── Rentang port simulator ───────────────────────────────────────────────────
# Behavio membuka SATU PORT PER SIMULATOR (design.md §6.1) — bank mulai 9001,
# QRIS mulai 9101, dialokasikan `platform.port_registry`. Port ini yang dipanggil
# klien/Postman, BUKAN port Admin API. Tanpa dipetakan, simulator jalan di dalam
# container tapi tak bisa dihubungi dari luar.
SIM_PORT_START=9000
SIM_PORT_END=9199

# ── Target deploy (dipakai deploy/deploy.sh) ─────────────────────────────────
DEPLOY_HOST=ganti-host-server
DEPLOY_USER=ganti-user-ssh
DEPLOY_DIR=/opt/behavio

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Dipakai service `cloudflared` di deploy/docker-compose.yml.
#
# WAJIB diisi selama service `cloudflared` masih ada di compose. Nilai kosong kini
# DITOLAK oleh deploy.sh dan oleh compose sendiri — dulu tidak, dan akibatnya
# cloudflared jalan dengan `--token ` lalu mati-hidup selamanya sementara deploy
# melaporkan "selesai". Kalau memang tak memakai tunnel, HAPUS service-nya dari
# deploy/docker-compose.yml, jangan sekadar mengosongkan baris ini.
#
# Ambil tokennya di Cloudflare Zero Trust → Networks → Tunnels → Configure.
# Origin tunnel harus menunjuk `http://frontend:80` (nginx dashboard) — bukan
# localhost, dan bukan backend yang memakai network_mode: host.
CLOUDFLARE_TUNNEL_TOKEN=
