# Gradle — pola GENERIK, berlaku untuk semua modul: backend/, backend-split/, dan yang
# menyusul. Sebelumnya polanya dipatok ke "backend/" saja, sehingga saat backend-split/
# lahir seluruh artefak build-nya ikut ter-commit (357 file / 67 MB).
**/.gradle/
**/build/
# Kecuali wrapper: gradle-wrapper.jar WAJIB ter-track supaya ./gradlew jalan di mesin lain.
!**/gradle/wrapper/gradle-wrapper.jar

# frontend
frontend/node_modules/
frontend/dist/
frontend/.angular/

# rahasia — .env memuat kredensial DB & token tunnel (lihat .env.example)
# JANGAN dilonggarkan: deploy/.gitignore hanya menutup deploy/, sedangkan deploy.sh
# membaca .env dari ROOT repo — tanpa baris ini, satu `git add .` membocorkannya.
.env
.env.*
!.env.example

# misc
*.log
.DS_Store
.idea/
